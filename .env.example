# Copy this file to .env and fill in local secrets.
# Do not commit .env.

WEBTASK_PLANNER=hybrid
WEBTASK_HEADLESS=true

# OpenAI or any OpenAI-compatible chat-completions provider.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional for OpenAI-compatible providers.
# OPENAI_BASE_URL=https://api.openai.com/v1

WEBTASK_LLM_TEMPERATURE=0
WEBTASK_LLM_TIMEOUT=60
WEBTASK_LLM_MAX_RETRIES=2
